{
  "name": "clothes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && node --watch dist/server/src/index.js",
    "start": "node dist/server/src/index.js",
    "amazon:login": "node scripts/amazon-login.mjs",
    "taobao:login": "node scripts/taobao-login.mjs",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/server/tests/*.test.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "multer": "^2.0.2",
    "nanoid": "^5.1.0",
    "openai": "^5.0.1",
    "playwright-core": "^1.60.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.5",
    "typescript": "^5.7.3"
  }
}
