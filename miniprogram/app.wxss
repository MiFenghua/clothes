page {
  min-height: 100vh;
  background: #f7f7fb;
  color: #17181c;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", sans-serif;
  font-size: 28rpx;
}

view,
text,
image,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: normal;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: calc(env(safe-area-inset-top) + 28rpx) 32rpx calc(env(safe-area-inset-bottom) + 56rpx);
}

.app-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 20% 2%, rgba(140, 119, 255, 0.12) 0, rgba(140, 119, 255, 0) 300rpx),
    linear-gradient(180deg, #ffffff 0%, #f7f7fb 54%, #f6f5fb 100%);
  padding: calc(env(safe-area-inset-top) + 28rpx) 32rpx calc(env(safe-area-inset-bottom) + 48rpx);
}

.topbar {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.topbar-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  line-height: 44rpx;
  font-weight: 700;
  color: #17181c;
}

.nav-icon,
.icon-button {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #17181c;
  font-size: 36rpx;
  line-height: 64rpx;
}

.icon-button {
  border: 1rpx solid rgba(23, 24, 28, 0.08);
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 12rpx 30rpx rgba(39, 36, 64, 0.06);
}

.card {
  border: 1rpx solid rgba(23, 24, 28, 0.08);
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.86);
  box-shadow: 0 20rpx 60rpx rgba(39, 36, 64, 0.06);
}

.muted {
  color: #8a8c96;
}

.primary-button,
.secondary-button {
  height: 96rpx;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 29rpx;
  font-weight: 700;
}

.primary-button {
  color: #fff;
  background: linear-gradient(135deg, #8a72ff 0%, #755bff 100%);
  box-shadow: 0 18rpx 34rpx rgba(117, 91, 255, 0.24);
}

.primary-button[disabled],
.disabled {
  color: rgba(255, 255, 255, 0.72);
  background: #d5d2e4;
  box-shadow: none;
}

.secondary-button {
  color: #17181c;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(23, 24, 28, 0.12);
}

.pill {
  min-height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #8068ff;
  background: rgba(138, 114, 255, 0.12);
}

.fine-print {
  color: #9b9da7;
  font-size: 23rpx;
  line-height: 34rpx;
}
