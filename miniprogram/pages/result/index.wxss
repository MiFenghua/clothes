.result-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 44rpx);
}

.top-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.match-panel {
  margin-top: 22rpx;
  padding: 8rpx 12rpx 0;
}

.match-label {
  display: block;
  color: #8a8c96;
  font-size: 23rpx;
  line-height: 32rpx;
}

.match-row {
  margin-top: 2rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.match-score {
  color: #8068ff;
  font-size: 52rpx;
  line-height: 58rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.match-copy {
  flex: 1;
  min-width: 0;
  padding-bottom: 8rpx;
  color: #696c76;
  text-align: right;
  font-size: 25rpx;
  line-height: 34rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.match-meter {
  width: 280rpx;
  height: 10rpx;
  margin-top: 10rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(128, 104, 255, 0.16);
}

.match-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #9f8aff 0%, #755bff 100%);
}

.try-card {
  height: 918rpx;
  margin-top: 28rpx;
  overflow: hidden;
  position: relative;
  background:
    radial-gradient(circle at 28% 8%, rgba(128, 104, 255, 0.14) 0, rgba(128, 104, 255, 0) 300rpx),
    linear-gradient(180deg, #f7f5fb 0%, #f3f3f6 100%);
}

.try-image {
  width: 100%;
  height: 100%;
}

.try-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-model {
  width: 340rpx;
  height: 720rpx;
  position: relative;
}

.model-hair {
  position: absolute;
  left: 104rpx;
  top: 8rpx;
  width: 136rpx;
  height: 198rpx;
  border-radius: 78rpx 78rpx 46rpx 46rpx;
  background: #322625;
  box-shadow: -24rpx 40rpx 0 #3d302f, 30rpx 54rpx 0 #3d302f;
}

.model-face {
  position: absolute;
  left: 132rpx;
  top: 34rpx;
  width: 82rpx;
  height: 104rpx;
  border-radius: 48% 48% 44% 44%;
  background: #f1d8cb;
  z-index: 3;
}

.model-jacket {
  position: absolute;
  left: 58rpx;
  top: 152rpx;
  width: 224rpx;
  height: 260rpx;
  border: 3rpx solid rgba(82, 67, 54, 0.20);
  border-radius: 28rpx 28rpx 40rpx 40rpx;
  background: #f1eadf;
  z-index: 2;
}

.model-top {
  position: absolute;
  left: 122rpx;
  top: 174rpx;
  width: 96rpx;
  height: 154rpx;
  border-radius: 20rpx;
  background: #fffdf8;
  z-index: 3;
}

.model-pants {
  position: absolute;
  left: 72rpx;
  top: 370rpx;
  width: 196rpx;
  height: 282rpx;
  border-radius: 24rpx 24rpx 52rpx 52rpx;
  background: #b7c7d1;
  box-shadow: inset 92rpx 0 0 rgba(255, 255, 255, 0.16);
}

.model-shoes {
  position: absolute;
  left: 70rpx;
  bottom: 24rpx;
  width: 200rpx;
  height: 36rpx;
  border-radius: 24rpx;
  background: linear-gradient(90deg, #f4eee5 0 46%, transparent 46% 54%, #f4eee5 54% 100%);
}

.sparkle {
  position: absolute;
  width: 38rpx;
  height: 38rpx;
}

.sparkle::before,
.sparkle::after {
  content: "";
  position: absolute;
  left: 17rpx;
  top: 0;
  width: 4rpx;
  height: 38rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.92);
}

.sparkle::after {
  transform: rotate(90deg);
}

.sparkle-a {
  top: 54rpx;
  right: 76rpx;
}

.sparkle-b {
  top: 126rpx;
  right: 154rpx;
  transform: scale(0.56);
}

.try-tools {
  position: absolute;
  right: 22rpx;
  bottom: 68rpx;
  width: 88rpx;
  padding: 22rpx 0;
  border-radius: 44rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 18rpx 42rpx rgba(39, 36, 64, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.tool-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  color: #4c4f58;
  font-size: 20rpx;
  line-height: 26rpx;
  font-weight: 700;
}

.tool-icon {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  border: 2rpx solid #17181c;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #17181c;
  font-size: 22rpx;
}

.highlight {
  margin-top: 34rpx;
  padding: 0 8rpx;
}

.highlight-title,
.highlight-copy {
  display: block;
}

.highlight-title {
  font-size: 31rpx;
  line-height: 42rpx;
  font-weight: 800;
}

.highlight-copy {
  margin-top: 14rpx;
  color: #5f626d;
  font-size: 27rpx;
  line-height: 44rpx;
}

.buy-row {
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.buy-button {
  flex: 1;
}

.bag-button {
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 1rpx solid rgba(23, 24, 28, 0.12);
  color: #17181c;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 800;
  box-shadow: 0 14rpx 30rpx rgba(39, 36, 64, 0.06);
}

.detail-card {
  margin-top: 36rpx;
  padding: 28rpx 0 28rpx;
  background: rgba(255, 255, 255, 0.92);
}

.detail-tabs {
  height: 72rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  align-items: center;
  padding: 0 42rpx;
  color: #8a8c96;
  font-size: 27rpx;
  font-weight: 700;
  text-align: center;
}

.detail-tab {
  position: relative;
}

.detail-tab.active {
  color: #8068ff;
}

.detail-tab.active::after {
  content: "";
  position: absolute;
  left: 50%;
  bottom: -20rpx;
  width: 108rpx;
  height: 4rpx;
  margin-left: -54rpx;
  border-radius: 999rpx;
  background: #8068ff;
}

.product-list {
  padding: 34rpx 28rpx 0;
}

.product-card {
  min-height: 190rpx;
  margin-bottom: 18rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(23, 24, 28, 0.08);
  border-radius: 24rpx;
  background: #fff;
  display: flex;
  gap: 20rpx;
}

.product-image {
  width: 154rpx;
  height: 154rpx;
  border-radius: 20rpx;
  background: #f2f1f5;
  flex-shrink: 0;
}

.product-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.product-title {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  color: #17181c;
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 800;
}

.shop {
  margin-top: 8rpx;
  color: #a1a2aa;
  font-size: 23rpx;
  line-height: 32rpx;
}

.product-bottom {
  margin-top: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.price,
.price-text {
  color: #17181c;
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 800;
}

.price-text {
  font-size: 24rpx;
}

.buy-link {
  min-width: 138rpx;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 29rpx;
  border: 1rpx solid rgba(23, 24, 28, 0.14);
  color: #17181c;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
}

.empty-products {
  margin: 34rpx 28rpx 0;
  min-height: 180rpx;
  border-radius: 24rpx;
  background: #f8f8fc;
  color: #8a8c96;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 27rpx;
}

.more-card {
  margin: 28rpx 28rpx 0;
  min-height: 136rpx;
  padding: 26rpx 30rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(138, 114, 255, 0.12) 0%, rgba(138, 114, 255, 0.05) 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.more-title,
.more-copy {
  display: block;
}

.more-title {
  color: #17181c;
  font-size: 28rpx;
  line-height: 38rpx;
  font-weight: 800;
}

.more-copy {
  margin-top: 8rpx;
  color: #8a8c96;
  font-size: 24rpx;
  line-height: 34rpx;
}

.more-arrow {
  color: #17181c;
  font-size: 42rpx;
}
