.progress-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 48rpx);
}

.ghost {
  opacity: 0;
}

.score-card {
  margin-top: 22rpx;
  padding: 8rpx 20rpx 0;
}

.score-label {
  display: block;
  color: #8a8c96;
  font-size: 24rpx;
  line-height: 34rpx;
}

.score-row {
  margin-top: 4rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 18rpx;
}

.score-value {
  color: #8068ff;
  font-size: 54rpx;
  line-height: 60rpx;
  font-weight: 800;
  letter-spacing: -1rpx;
}

.score-message {
  flex: 1;
  min-width: 0;
  padding-bottom: 8rpx;
  color: #6f727e;
  text-align: right;
  font-size: 25rpx;
  line-height: 34rpx;
}

.meter {
  width: 100%;
  height: 10rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: rgba(128, 104, 255, 0.16);
}

.meter-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #9f8aff 0%, #755bff 100%);
  transition: width 0.25s ease;
}

.canvas-card {
  height: 820rpx;
  margin-top: 28rpx;
  position: relative;
  overflow: hidden;
  background:
    radial-gradient(circle at 30% 6%, rgba(128, 104, 255, 0.14) 0, rgba(128, 104, 255, 0) 260rpx),
    linear-gradient(180deg, #f7f5fb 0%, #f4f4f7 100%);
}

.star {
  position: absolute;
  width: 34rpx;
  height: 34rpx;
}

.star::before,
.star::after {
  content: "";
  position: absolute;
  left: 15rpx;
  top: 0;
  width: 4rpx;
  height: 34rpx;
  border-radius: 4rpx;
  background: rgba(255, 255, 255, 0.92);
}

.star::after {
  transform: rotate(90deg);
}

.star-one {
  right: 74rpx;
  top: 54rpx;
}

.star-two {
  right: 150rpx;
  top: 128rpx;
  transform: scale(0.58);
}

.ai-model {
  position: absolute;
  left: 50%;
  bottom: 52rpx;
  width: 300rpx;
  height: 640rpx;
  margin-left: -150rpx;
}

.model-hair {
  position: absolute;
  left: 94rpx;
  top: 0;
  width: 120rpx;
  height: 178rpx;
  border-radius: 72rpx 72rpx 46rpx 46rpx;
  background: #322625;
  box-shadow: -22rpx 34rpx 0 #3d302f, 26rpx 48rpx 0 #3d302f;
}

.model-face {
  position: absolute;
  left: 116rpx;
  top: 22rpx;
  width: 78rpx;
  height: 96rpx;
  border-radius: 48% 48% 44% 44%;
  background: #f1d8cb;
  z-index: 3;
}

.model-jacket {
  position: absolute;
  left: 58rpx;
  top: 132rpx;
  width: 194rpx;
  height: 230rpx;
  border: 3rpx solid rgba(82, 67, 54, 0.20);
  border-radius: 24rpx 24rpx 34rpx 34rpx;
  background: #f1eadf;
  z-index: 2;
}

.model-top {
  position: absolute;
  left: 106rpx;
  top: 150rpx;
  width: 92rpx;
  height: 142rpx;
  border-radius: 20rpx;
  background: #fffdf8;
  z-index: 3;
}

.model-pants {
  position: absolute;
  left: 70rpx;
  top: 322rpx;
  width: 168rpx;
  height: 250rpx;
  border-radius: 22rpx 22rpx 46rpx 46rpx;
  background: #b7c7d1;
  box-shadow: inset 78rpx 0 0 rgba(255, 255, 255, 0.16);
  z-index: 1;
}

.model-shoes {
  position: absolute;
  left: 70rpx;
  bottom: 20rpx;
  width: 172rpx;
  height: 34rpx;
  border-radius: 24rpx;
  background: linear-gradient(90deg, #f4eee5 0 46%, transparent 46% 54%, #f4eee5 54% 100%);
}

.tool-rail {
  position: absolute;
  right: 22rpx;
  bottom: 76rpx;
  width: 84rpx;
  padding: 22rpx 0;
  border-radius: 42rpx;
  background: rgba(255, 255, 255, 0.88);
  box-shadow: 0 18rpx 42rpx rgba(39, 36, 64, 0.08);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.tool-rail view {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid #17181c;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
}

.tool-rail text {
  color: #4c4f58;
  font-size: 20rpx;
  line-height: 26rpx;
}

.steps-card {
  margin-top: 28rpx;
  padding: 28rpx 28rpx 12rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.section-title {
  font-size: 30rpx;
  line-height: 42rpx;
  font-weight: 800;
}

.section-subtitle {
  color: #9b9da7;
  font-size: 24rpx;
}

.step {
  min-height: 116rpx;
  display: flex;
  align-items: flex-start;
  position: relative;
  padding-top: 22rpx;
}

.step-dot {
  width: 24rpx;
  height: 24rpx;
  margin-top: 7rpx;
  border-radius: 50%;
  border: 3rpx solid #d6d4e2;
  background: #fff;
  z-index: 2;
}

.step-line {
  position: absolute;
  left: 11rpx;
  top: 54rpx;
  bottom: -20rpx;
  width: 2rpx;
  background: #eceaf3;
}

.step:last-child .step-line {
  display: none;
}

.step.done .step-dot {
  border-color: #8068ff;
  background: #8068ff;
}

.step.active .step-dot {
  border-color: #8068ff;
  background: #fff;
  box-shadow: 0 0 0 12rpx rgba(128, 104, 255, 0.12);
}

.step-copy {
  flex: 1;
  margin-left: 22rpx;
}

.step-title,
.step-desc {
  display: block;
}

.step-title {
  font-size: 29rpx;
  line-height: 38rpx;
  font-weight: 800;
}

.step.todo .step-title {
  color: #9b9da7;
}

.step-desc {
  margin-top: 6rpx;
  color: #7a7d87;
  font-size: 24rpx;
  line-height: 34rpx;
}
