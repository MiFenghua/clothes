.error-page {
  padding-bottom: calc(env(safe-area-inset-bottom) + 48rpx);
}

.ghost {
  opacity: 0;
}

.error-card {
  margin-top: 74rpx;
  min-height: 640rpx;
  padding: 48rpx 34rpx 36rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.error-visual {
  width: 188rpx;
  height: 188rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.error-mark {
  width: 116rpx;
  height: 116rpx;
  border-radius: 58rpx;
  color: #fff;
  background: linear-gradient(135deg, #8a72ff 0%, #755bff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 66rpx;
  line-height: 92rpx;
  font-weight: 900;
  z-index: 2;
  box-shadow: 0 20rpx 42rpx rgba(117, 91, 255, 0.26);
}

.orbit {
  position: absolute;
  border: 2rpx solid rgba(128, 104, 255, 0.20);
  border-radius: 50%;
}

.orbit-a {
  width: 168rpx;
  height: 118rpx;
  transform: rotate(-22deg);
}

.orbit-b {
  width: 150rpx;
  height: 104rpx;
  transform: rotate(28deg);
}

.error-title {
  display: block;
  margin-top: 26rpx;
  color: #17181c;
  font-size: 38rpx;
  line-height: 50rpx;
  font-weight: 800;
}

.message {
  display: block;
  margin-top: 18rpx;
  max-width: 560rpx;
  color: #686b75;
  font-size: 28rpx;
  line-height: 44rpx;
}

.tips {
  width: 100%;
  margin-top: 42rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(23, 24, 28, 0.08);
  border-radius: 28rpx;
  background: #f8f8fc;
  text-align: left;
}

.tips-title {
  display: block;
  margin-bottom: 16rpx;
  color: #17181c;
  font-size: 27rpx;
  line-height: 36rpx;
  font-weight: 800;
}

.tip-item {
  min-height: 42rpx;
  padding-left: 26rpx;
  position: relative;
  color: #696c76;
  font-size: 25rpx;
  line-height: 42rpx;
}

.tip-item::before {
  content: "";
  position: absolute;
  left: 0;
  top: 17rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #8068ff;
}

.retry {
  margin-top: 44rpx;
}

.later {
  margin-top: 18rpx;
}
