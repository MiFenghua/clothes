<view class="app-page error-page">
  <view class="topbar">
    <button class="nav-icon" bindtap="goHome">‹</button>
    <text class="topbar-title">生成失败</text>
    <view class="nav-icon ghost"></view>
  </view>

  <view class="error-card card">
    <view class="error-visual">
      <view class="error-mark">!</view>
      <view class="orbit orbit-a"></view>
      <view class="orbit orbit-b"></view>
    </view>
    <text class="error-title">本次试穿图生成失败</text>
    <text class="message">{{message}}</text>

    <view class="tips">
      <text class="tips-title">重新上传前建议确认</text>
      <view class="tip-item">人物尽量完整入镜</view>
      <view class="tip-item">脸部清晰可见</view>
      <view class="tip-item">光线充足且无遮挡</view>
    </view>
  </view>

  <button class="primary-button retry" bindtap="goHome">重新上传</button>
  <button class="secondary-button later" bindtap="goHome">稍后再试</button>
</view>
