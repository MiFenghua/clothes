<view class="app-page home-page">
  <view class="brand-row">
    <view class="logo">
      <text>cloz</text><text class="logo-accent">Ai</text>
    </view>
    <view class="bell-button">
      <view class="bell-ring"></view>
    </view>
  </view>

  <view class="hero-copy">
    <view>
      <text class="hello">你好，今天想尝试</text>
      <text class="headline">什么风格的穿搭呢？</text>
    </view>
    <button class="upload-pill" bindtap="choosePhoto">
      <text>{{photoPath ? '更换照片' : '上传照片'}}</text>
      <text class="plus">+</text>
    </button>
  </view>

  <view class="photo-preview card" wx:if="{{photoPath}}" bindtap="choosePhoto">
    <image class="photo-image" src="{{photoPath}}" mode="aspectFill" />
    <view class="photo-mask">
      <text>已选择全身照</text>
      <text>点击可重新上传</text>
    </view>
  </view>

  <view class="feature-card card">
    <view class="section-head">
      <text class="section-title">我的特征分析</text>
      <text class="section-link">{{photoPath ? '已准备分析' : '上传后生成'}} ›</text>
    </view>

    <view class="feature-body">
      <view class="body-panel">
        <view class="measure-line line-top"></view>
        <view class="measure-line line-mid"></view>
        <view class="measure-line line-bottom"></view>
        <view class="body-figure">
          <view class="figure-head"></view>
          <view class="figure-shoulder"></view>
          <view class="figure-torso"></view>
          <view class="figure-legs">
            <view></view>
            <view></view>
          </view>
        </view>
      </view>

      <view class="feature-list">
        <view wx:for="{{analysisFeatures}}" wx:key="label" class="feature-item">
          <view class="feature-icon">{{item.icon}}</view>
          <view>
            <text class="feature-label">{{item.label}}</text>
            <text class="feature-value">{{item.value}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="preference-card card">
    <view class="section-head">
      <text class="section-title">今日偏好</text>
      <text class="section-link">默认可直接生成</text>
    </view>

    <view class="pref-block">
      <text class="pref-label">穿搭场景</text>
      <scroll-view class="chip-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="chip-track">
          <view wx:for="{{scenes}}" wx:key="value" class="choice-chip {{form.scene === item.value ? 'choice-active' : ''}}" data-value="{{item.value}}" bindtap="selectScene">{{item.label}}</view>
        </view>
      </scroll-view>
    </view>

    <view class="pref-block">
      <text class="pref-label">预算</text>
      <scroll-view class="chip-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="chip-track">
          <view wx:for="{{budgets}}" wx:key="label" class="choice-chip {{budgetIndex === index ? 'choice-active' : ''}}" data-index="{{index}}" bindtap="selectBudget">{{item.label}}</view>
        </view>
      </scroll-view>
    </view>

    <view class="quick-fields">
      <view class="quick-field">
        <text>身高</text>
        <input type="number" placeholder="168cm" value="{{form.heightCm}}" data-key="heightCm" bindinput="onInput" />
      </view>
      <view class="quick-field">
        <text>尺码</text>
        <input placeholder="M" value="{{form.usualSize}}" data-key="usualSize" bindinput="onInput" />
      </view>
    </view>

    <view class="text-field">
      <text>喜欢风格</text>
      <input placeholder="清新、优雅、简约" value="{{form.likedStyle}}" data-key="likedStyle" bindinput="onInput" />
    </view>
    <view class="text-field">
      <text>避雷项</text>
      <input placeholder="不喜欢的颜色、版型或风格" value="{{form.avoid}}" data-key="avoid" bindinput="onInput" />
    </view>
  </view>

  <view class="recommend-section">
    <view class="section-head">
      <text class="section-title">为你推荐的穿搭</text>
      <text class="section-link">查看更多 ›</text>
    </view>
    <scroll-view class="look-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="look-track">
        <view wx:for="{{looks}}" wx:key="title" class="look-card tone-{{item.tone}}">
          <view wx:if="{{index === 0}}" class="today-tag">今日推荐</view>
          <view class="look-person">
            <view class="look-head"></view>
            <view class="look-hair"></view>
            <view class="look-top"></view>
            <view class="look-bottom"></view>
          </view>
          <text class="look-title">{{item.title}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <button class="primary-button submit-button" disabled="{{!photoPath || submitting}}" loading="{{submitting}}" bindtap="submitTask">
    {{photoPath ? '生成我的穿搭' : '先上传全身照'}}
  </button>

  <view class="bottom-tabs">
    <view wx:for="{{tabs}}" wx:key="label" class="tab-item {{index === 0 ? 'tab-active' : ''}}">
      <text class="tab-icon">{{item.icon}}</text>
      <text>{{item.label}}</text>
    </view>
  </view>
</view>
